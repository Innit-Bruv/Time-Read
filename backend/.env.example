# Backend environment variables — copy to .env and fill in real values.
# Never commit .env to version control.

# Environment: "development" or "production"
ENV=development

# Internal API secret shared between Next.js proxy and FastAPI.
# Must NOT be the default value in production (startup will refuse to start).
INTERNAL_API_SECRET=dev-secret-change-me

# OpenAI — required for embedding and LLM recommendation features
OPENAI_API_KEY=sk-...

# PostgreSQL connection string (with pgvector extension installed)
DATABASE_URL=postgresql://user:password@localhost:5432/timeread

# Redis — used by Celery for task queue and result backend
REDIS_URL=redis://localhost:6379

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000
